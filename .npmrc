# React Native + native modules need a flat (hoisted) node_modules layout.
# pnpm's default symlinked store breaks Metro's resolver and Gradle/CocoaPods
# autolinking, so we hoist. See CONTRIBUTING.md for the rationale.
node-linker=hoisted

# RN and its large peer-dependency graph routinely declare conflicting/loose
# peers; don't fail installs on them (warn instead).
strict-peer-dependencies=false
auto-install-peers=true

# Keep the lockfile honest in CI.
prefer-frozen-lockfile=true
