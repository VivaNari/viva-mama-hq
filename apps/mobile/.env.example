# VivaMama mobile app — environment (loaded via react-native-dotenv / `@env`).
# Copy to `.env`. NEVER commit your real .env.
#
# ⚠️  Everything here is bundled into the app binary at build time, so treat it
#     as PUBLIC. Never place server-side secrets (DB URIs, payment SECRET keys,
#     JWT secrets) in this file — those belong only on the backend.

# Backend API base URL (no trailing slash). Falls back to http://localhost:4000.
BASE_API_URL=http://localhost:4000
API_VERSION=v1

# Google Sign-In OAuth *web client ID* (public; safe to ship in a client).
GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Razorpay *publishable key id* ONLY (rzp_test_… / rzp_live_…).
# Do NOT add RAZORPAY_SECRET_KEY here — order creation/verification is signed on
# the backend. Shipping the secret in the app would expose your payment account.
RAZORPAY_API_KEY=rzp_test_your_key_id

# ── Firebase (NOT committed) ─────────────────────────────────────────
# Download from the Firebase console and place these files manually; they are
# git-ignored:
#   android/app/google-services.json
#   ios/<App>/GoogleService-Info.plist
