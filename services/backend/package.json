{
    "name": "@vivamama/backend",
    "version": "1.0.0",
    "description": "VivaMama core API — Node.js + TypeScript + Express 5 service (MongoDB, Redis) powering onboarding, check-ins, the Viva Recovery Score, recommendations, payments and chat.",
    "main": "index.js",
    "scripts": {
        "clean": "rimraf dist",
        "rebuild": "npm run clean && npm run build",
        "test": "NODE_ENV=test jest",
        "dev": "nodemon --exec ts-node src/index.ts",
        "build": "tsc",
        "cron:core-job": "ts-node src/cron-jobs/currentWeekAndPreviousUpcomingDueDaysCalculator",
        "start": "node build/index.js",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "k6:login": "k6 run load-tests/k6/login.js",
        "k6:checkin": "k6 run load-tests/k6/weekly-checkin-onboarding.js",
        "k6:products": "k6 run load-tests/k6/products.js",
        "k6:vivaclub": "k6 run load-tests/k6/viva-club.js"
    },
    "lint-staged": {
        "*.{ts,js}": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "keywords": [],
    "author": "",
    "license": "Apache-2.0",
    "type": "commonjs",
    "dependencies": {
        "@vivamama/contracts": "workspace:*",
        "axios": "^1.13.2",
        "cors": "^2.8.5",
        "dotenv": "^17.2.3",
        "express": "^5.1.0",
        "firebase-admin": "^13.6.0",
        "google-auth-library": "^10.4.0",
        "http-status-codes": "^2.3.0",
        "ioredis": "^5.8.2",
        "joi": "^18.0.1",
        "jsonwebtoken": "^9.0.2",
        "mongoose": "^8.19.0",
        "mongoose-sequence": "^6.0.1",
        "node-cron": "^4.2.1",
        "pino": "^10.1.0",
        "pino-http": "^11.0.0",
        "razorpay": "^2.9.6",
        "socket.io": "^4.8.1",
        "supertest": "^7.1.4",
        "twilio": "^5.10.2",
        "uuid": "^13.0.0"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.2",
        "@commitlint/config-conventional": "^21.0.2",
        "@eslint/eslintrc": "^3.3.1",
        "@types/cors": "^2.8.19",
        "@types/dotenv": "^8.2.3",
        "@types/express": "^5.0.3",
        "@types/http-status-codes": "^1.2.0",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/mongoose-sequence": "^3.0.11",
        "@types/node": "^25.9.3",
        "@types/supertest": "^7.2.0",
        "@typescript-eslint/eslint-plugin": "^8.61.1",
        "@typescript-eslint/parser": "^8.61.1",
        "eslint": "^10.5.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-airbnb-typescript": "^18.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.4",
        "husky": "^9.1.7",
        "jest": "^30.4.2",
        "lint-staged": "^17.0.7",
        "nodemon": "^3.1.10",
        "prettier": "^3.8.4",
        "rimraf": "^6.0.1",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^6.0.3"
    },
    "overrides": {
        "@tootallnate/once": "^3.0.1",
        "http-proxy-agent": "^7.0.0"
    }
}