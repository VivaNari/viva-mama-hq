# VivaMama RAG Chatbot — environment configuration
# Copy to `.env` and fill in real values. NEVER commit a real .env.
# All keys map 1:1 to app/settings.py (case-insensitive).

# Runtime environment: dev | staging | production
ENV=dev

# ── Groq LLM (REQUIRED) ──────────────────────────────────────────────
# Get a key at https://console.groq.com/keys (must start with "gsk_").
GROQ_API_KEY=gsk_your_groq_api_key_here
LLM_MODEL=llama-3.3-70b-versatile
SCOPE_CLASSIFIER_MODEL=llama-3.1-8b-instant

# ── Internal API auth (REQUIRED) ─────────────────────────────────────
# Generate a strong key:  openssl rand -hex 32
API_KEY=replace_with_a_strong_random_key

# ── Redis (session memory) ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
MEMORY_TTL_SECONDS=7200

# ── RAG retrieval ────────────────────────────────────────────────────
EMBEDDINGS_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_VECTOR_DIR=.local_vector_store
RAG_TOP_K=6
# Minimum cosine/L2 similarity (0–1) for a chunk to be used as grounding context.
RAG_SCORE_THRESHOLD=0.40

# ── Product catalog source: local | mcp ──────────────────────────────
PRODUCTS_SOURCE=local

# ── MongoDB ──────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DATABASE=viva_mama
